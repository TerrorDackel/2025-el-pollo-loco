{
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "prepare": "husky",
    "build": "node scripts/build.js",
    "lint": "eslint js models levels",
    "format": "prettier . --write",
    "format:check": "prettier \"js/**/*.js\" \"models/**/*.js\" \"levels/**/*.js\" \"styles/**/*.css\" \"index.html\" \"eslint.config.js\" \"vitest.config.js\" \".prettierrc.json\" --check",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "lint-staged": {
    "*.{css,html,json,md}": [
      "prettier --write"
    ],
    "js/**/*.js": [
      "eslint --fix"
    ],
    "models/**/*.js": [
      "eslint --fix"
    ],
    "levels/**/*.js": [
      "eslint --fix"
    ]
  }
}
